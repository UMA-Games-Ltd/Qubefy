# Recommended: link this folder to the Netlify project and let `netlify dev`
# pull env vars from the cloud — no secrets on disk.
#
#   netlify login
#   netlify link --name uma-qubefy
#   npm run dev:netlify
#
# Fallback: if you can't link (no team access), copy this file to `.env`
# and fill in the value. `.env` is gitignored.

OPENROUTER_API_KEY=
